{
  "name": "@crc/shared",
  "version": "0.1.0",
  "description": "Shared types, protocol definitions, and crypto primitives for CRC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "keywords": ["codex", "remote-control", "ai-agent", "e2ee", "json-rpc", "websocket"],
  "license": "MIT",
  "author": "Chakib Bouabd",
  "repository": {
    "type": "git",
    "url": "https://github.com/chakib-b/codex-remote-control",
    "directory": "packages/shared"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
