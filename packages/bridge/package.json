{
  "name": "@crc/bridge",
  "version": "0.1.0",
  "description": "Mac CLI bridge for CRC — spawns AI agents, connects to relay, bridges messages to mobile",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crc": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "keywords": ["codex", "remote-control", "ai-agent", "bridge", "git", "cli", "e2ee"],
  "license": "MIT",
  "author": "Chakib Bouabd",
  "repository": {
    "type": "git",
    "url": "https://github.com/chakib-b/codex-remote-control",
    "directory": "packages/bridge"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@crc/shared": "workspace:*",
    "ws": "^8.18.0",
    "commander": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@types/qrcode-terminal": "^0.12.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
